---
import '../styles/global.css';
import BackButton from '../components/Common/BackButton.astro';


interface Props {
  title?: string;
  showBackButton?: boolean;
}

const { title = 'Dachhelden',  showBackButton = false } = Astro.props;
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,200,0,0&icon_names=crossword" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css">

    <title>{title}</title>
  </head>
  <body>
    <nav class="navbar">
      <div class="navbar__container">
        <div class="navbar__title">
          <div class="navbar__left">
          {showBackButton && (
            <button id="back-button" class="navbar__back" type="button">
              ← Zurück
            </button>
          )}
        </div>
          <span class="material-symbols-outlined">crossword </span> 
          <h1 class="navbar__brand">Dachhelden</h1>
        </div>
          <div class="navbar__links">
          <a href="/dachhelden/admin/dashboard" class="navbar__link">Admin</a>
          <a href="/dachhelden/worker/dashboard" class="navbar__link">Mitarbeiter</a>
          <a href="/dachhelden/public/dashboard" class="navbar__link">Übersicht</a>
        </div>
      </div>
    </nav>
    <main class="main-container">
      <div class="page-container">
        <slot />
      </div>
    </main>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .navbar {
    border-bottom: 0.5px solid var(--border);
    background-color: var(--surface-2);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .navbar__brand {
    font-size: var(--font-size-2xl);
    font-weight: 700;
    color: var(--text-primary);
  }

  .navbar__title {
    display: flex;
    gap: 16px;
    align-items: center;
  }

  .navbar__links {
    display: flex;
    gap: 2rem;
  }

  .navbar__link {
    color: var(--text-secondary);
    font-weight: 500;
    transition: color 0.2s;
  }

  .navbar__link:hover {
    color: var(--text-accent);
    text-decoration: none;
  }

  .main-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .page-container {
  padding: 2rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.navbar__left {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.navbar__back {
  padding: 0.5rem 0.75rem;
  background: transparent;
  border: 1px solid var(--border);
  border-radius: var(--radius);
  color: var(--text-primary);
  cursor: pointer;
  transition: all .2s ease;
}

.navbar__back:hover {
  background: var(--surface-1);
}
</style>
<script>
  const backButton = document.querySelector<HTMLButtonElement>('#back-button');

  backButton?.addEventListener('click', () => {
    if (window.history.length > 1) {
      window.history.back();
    } else {
      window.location.href = '/';
    }
  });
</script>