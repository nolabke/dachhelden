---
import Button from '../Common/Button.astro';
import Card from '../Common/Card.astro';
---

<Card highlighted>
  <h3 class="form__title">Mitarbeitenden Punkte hinzufügen</h3>

  <form class="form" onsubmit="handleSubmit(event)">
    <div class="form__row form__row--2cols">
      <div class="form__group">
        <label class="form__label">Mitarbeitende auswählen</label>
        <select class="form__select" required>
          <option value="">-- Auswählen --</option>
          <option>Anne Müller</option>
          <option>Markus Schneider</option>
          <option>Sofia Weber</option>
        </select>
      </div>

      <div class="form__group">
        <label class="form__label">Kategorie</label>
        <select class="form__select" required>
          <option value="">-- Auswählen --</option>
          <option>Anwesenheit</option>
          <option>Pünktlichkeit</option>
          <option>Ziele</option>
          <option>Sonstiges</option>
        </select>
      </div>
    </div>

    <div class="form__row form__row--2cols">
      <div class="form__group">
        <label class="form__label">Punkteanzahl</label>
        <input type="number" class="form__input" value="10" min="1" required />
      </div>

      <div class="form__group">
        <label class="form__label">Begründung</label>
        <input
          type="text"
          class="form__input"
          placeholder="z. B. Kein Fehltag"
          required
        />
      </div>
    </div>

    <div class="form__actions">
      <Button variant="secondary" type="reset">Abbrechen</Button>
      <Button variant="primary" type="submit">Punkte hinzufügen</Button>
    </div>
  </form>
</Card>

<style>
  .form__title {
    font-size: var(--font-size-lg);
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form__row {
    display: grid;
    gap: var(--gap-lg);
  }

  .form__row--2cols {
    grid-template-columns: 1fr 1fr;
  }

  .form__group {
    display: flex;
    flex-direction: column;
  }

  .form__label {
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .form__input,
  .form__select {
    width: 100%;
    padding: 8px 12px;
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    font-size: var(--font-size-base);
    background-color: var(--surface-2);
    color: var(--text-primary);
  }

  .form__input:focus,
  .form__select:focus {
    outline: none;
    border-color: var(--fill-accent);
    box-shadow: 0 0 0 3px var(--bg-accent);
  }

  .form__actions {
    display: flex;
    justify-content: flex-end;
    gap: var(--gap-md);
    margin-top: 0.5rem;
  }
</style>