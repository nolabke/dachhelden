---
interface Props {
  ranking: {
    name: string;
    points: number;
  }[];
}

const { ranking } = Astro.props;

const medals = ['🥇', '🥈', '🥉'];
---

<div class="card">
  <h2 class="title">Wochenranking</h2>

  <table class="ranking-table">
    <thead>
      <tr>
        <th>Platz</th>
        <th>Mitarbeitende</th>
        <th style="text-align:right">Punkte</th>
      </tr>
    </thead>
    <tbody>
      {
        ranking.map((entry, index) => (
          <tr>
            <td>{medals[index] ?? index + 1}</td>
            <td>{entry.name}</td>
            <td style="text-align:right">{entry.points} pkt</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>


<style>
  .card {
    background: var(--surface-1);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.25rem;
  }

  .title {
    margin-bottom: 1rem;
    font-size: var(--font-size-xl);
  }

  table {
    width: 100%;
    border-collapse: collapse;
  }

  th,
  td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--border);
  }

  th {
  text-align:left;
  color:var(--text-secondary);
}


@media (max-width: 480px) {
  .ranking-table {
    padding: .75rem;
    word-break: break-word;
  }
}


</style>