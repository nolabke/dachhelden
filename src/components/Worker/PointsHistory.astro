---
interface HistoryItem {
  date: string;
  category: string;
  points: number;
  reason: string;
}

interface Props {
  history: HistoryItem[];
}

const { history } = Astro.props;
---

<div class="card">
  <h2 class="title">Punkteverlauf</h2>
  <table class="history-table">
    <thead>
      <tr>
        <th>Datum</th>
        <th>Kategorie</th>
        <th>Punkte</th>
        <th style="text-align:right">Grund</th>
      </tr>
    </thead>
    <tbody>
      {
        history.map((item) => (
          <tr>
            <td>{item.date}</td>
            <td>{item.category}</td>
            <td class="points">+{item.points}</td>
            <td style="text-align:right">{item.reason}</td>
          </tr>
        ))
      }
    </tbody>
  </table>
</div>


<style>

.card {
  background:var(--surface-1);
  border:1px solid var(--border);
  border-radius:12px;
  padding:1.25rem;
}


.title {
  margin-bottom:1rem;
}


.points {
  color:var(--text-success);
  font-weight:600;
}


.history-table {
  width:100%;
  border-collapse:collapse;
  font-size: var(--font-size-md);
  
}

.history-table th,
.history-table td {
  padding:.75rem;
  border-bottom:1px solid var(--border);
  word-break: break-word;
  
}


@media (max-width: 480px) {
  .history-table {
    padding: .75rem;
    word-break: break-word;
  }
}


</style>